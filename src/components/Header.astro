                    Contáctame
                </a>
                <div class="flex items-center gap-3" aria-label="Perfiles sociales">
                    <a href="https://github.com/ManuNH98" target="_blank" class="grid h-12 w-12 place-items-center rounded-full border border-zinc-700 bg-zinc-900/70 transition duration-200 hover:-translate-y-0.5 hover:border-yellow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow" aria-label="Perfil de GitHub de Manuel Navarro">
                        <img src="/assets/images/icons/logo-github-dark.svg" alt="Logo de GitHub" class="h-7 w-7">
                    </a>
                    <a href="https://www.linkedin.com/in/manuel-navarro-higueras/" target="_blank" class="grid h-12 w-12 place-items-center rounded-full border border-zinc-700 bg-zinc-900/70 transition duration-200 hover:-translate-y-0.5 hover:border-yellow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow" aria-label="Perfil de LinkedIn de Manuel Navarro">
