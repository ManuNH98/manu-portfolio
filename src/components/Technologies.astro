---
const technologies = [
    { name: "HTML", experience: "+4 años de experiencia" },
    { name: "CSS", experience: "+4 años de experiencia" },
    { name: "TailwindCSS", experience: "+3 años de experiencia" },
    { name: "React", experience: "+2 año de experiencia" },
    { name: "TypeScript", experience: "+2 años de experiencia" },
    { name: "NestJS", experience: "+2 año de experiencia" },
];
---

<section id="tecnologias" class="py-20 sm:py-24">
    <div class="mb-10 flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-yellow">Stack</p>
            <h2 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">Tecnologías</h2>
        </div>
        <a href="#contacto" class="w-fit border-b-2 border-yellow pb-2 text-base font-semibold text-white transition duration-200 hover:text-yellow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow focus-visible:ring-offset-4 focus-visible:ring-offset-zinc-950">Hablemos</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {technologies.map((technology, index) => (
            <article class="group rounded-3xl border border-zinc-800 bg-zinc-900/45 p-6 transition duration-300 hover:-translate-y-1 hover:border-yellow/50 hover:bg-zinc-900/80">
                <div class="mb-10 flex items-center justify-between text-sm text-zinc-500">
                    <span>0{index + 1}</span>
                    <span class="h-2 w-2 rounded-full bg-yellow opacity-60 transition duration-300 group-hover:opacity-100"></span>
                </div>
                <h3 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">{technology.name}</h3>
                <p class="mt-3 text-base text-zinc-400 sm:text-lg">{technology.experience}</p>
            </article>
        ))}
    </div>
</section>
