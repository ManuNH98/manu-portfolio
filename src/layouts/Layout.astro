---
import SpeedInsights from "@vercel/speed-insights/astro";
import "../styles/globals.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const { title } = Astro.props;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Portfolio de Manuel Navarro, desarrollador web especializado en crear soluciones digitales modernas y accesibles." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-zinc-950 text-white antialiased selection:bg-yellow selection:text-zinc-950">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute left-1/2 top-0 h-96 w-96 -translate-x-1/2 rounded-full bg-yellow/10 blur-3xl"></div>
      <div class="absolute right-0 top-1/3 h-80 w-80 rounded-full bg-zinc-700/20 blur-3xl"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.035)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.035)_1px,transparent_1px)] bg-[size:72px_72px] opacity-25"></div>
    </div>
    <div class="mx-auto flex min-h-screen w-full max-w-7xl flex-col px-5 microsm:px-6 sm:px-8 lg:px-10 xl:px-12">
      <Navbar />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
    <SpeedInsights />
  </body>
</html>
